project_id          = "your-gcp-project-id"
region              = "asia-south1"
service_name        = "omiryn"
artifact_repository = "omiryn"

sql_instance_name     = "omiryn-postgres"
sql_database_name     = "omiryn"
sql_user_name         = "omiryn_app"
sql_edition           = "ENTERPRISE"
sql_tier              = "db-f1-micro"
sql_disk_size_gb      = 10
sql_public_ip_enabled = true

# Prefer setting this interactively:
# terraform apply -var='sql_user_password=...'
sql_user_password = ""

# Keep false until an image has been pushed.
create_cloud_run_service = false
container_image          = ""

# Profile photo uploads. Leave bucket name empty to use PROJECT-service-profile-photos.
profile_photo_bucket_name        = ""
profile_photo_bucket_public_read = false

# Optional custom domain through Global HTTPS Load Balancer + Cloud CDN.
create_https_load_balancer  = false
load_balancer_domain_names  = []
load_balancer_enable_cdn    = true
load_balancer_http_redirect = true
