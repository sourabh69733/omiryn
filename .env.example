# Application
APP_ENV=local
APP_NAME=omiryn
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=debug

# Database
# Local default can be SQLite: sqlite:///./data/omiryn.db
# Local Postgres with Docker Compose:
# POSTGRES_DB=omiryn
# POSTGRES_USER=omiryn
# POSTGRES_PASSWORD=omiryn
# POSTGRES_PORT=5432
# DATABASE_URL=postgresql+psycopg://omiryn:omiryn@localhost:5432/omiryn
# Production should use hosted Postgres.
DATABASE_URL=sqlite:///./data/omiryn.db

# Profile photo uploads. Local disk is used unless PROFILE_PHOTO_GCS_BUCKET is set.
PROFILE_PHOTO_MAX_MB=10
PROFILE_PHOTO_GCS_BUCKET=omiryn_bucket
PROFILE_PHOTO_GCS_PREFIX=profile_photos
PROFILE_PHOTO_GCS_PUBLIC_READ=true

# Redis / queue
REDIS_URL=redis://localhost:6379/0

# AI providers
# Use "mock", "groq", "deepinfra", "fireworks", or "ollama".
AGENT_PROVIDER=mock
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_AVAILABLE_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile
GROQ_INPUT_COST_PER_1M=0
GROQ_OUTPUT_COST_PER_1M=0
DEEPINFRA_API_KEY=
# DEEPINFRA_TOKEN is also accepted if you prefer DeepInfra's naming.
DEEPINFRA_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
DEEPINFRA_AVAILABLE_MODELS=meta-llama/Llama-3.3-70B-Instruct-Turbo,meta-llama/Llama-3.1-70B-Instruct-Turbo,deepseek-ai/DeepSeek-V3
DEEPINFRA_INPUT_COST_PER_1M=0.10
DEEPINFRA_OUTPUT_COST_PER_1M=0.32
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/gpt-oss-120b
FIREWORKS_AVAILABLE_MODELS=accounts/fireworks/models/gpt-oss-120b,accounts/fireworks/models/llama-v3p3-70b-instruct,accounts/fireworks/models/deepseek-v3p1
FIREWORKS_INPUT_COST_PER_1M=0.15
FIREWORKS_OUTPUT_COST_PER_1M=0.60
USD_TO_INR=0
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_AVAILABLE_MODELS=llama3.1

# Security
SECRET_KEY=change-me-in-local-env
ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Base64 urlsafe 32-byte key for app-level encrypted storage.
# Generate with: python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_MASTER_KEY=

# Auth
# Current adapter: supabase. Future adapters can use the same app-level identity contract.
AUTH_PROVIDER=supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWT_AUDIENCE=authenticated
# If unset, auth is required by default when an auth provider is configured.
AUTH_REQUIRED=true
# Set true only for admin/dev views. Shows raw internal profile data points in the UI.
PROFILE_DEBUG_DATA_ENABLED=false

# Messaging
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
