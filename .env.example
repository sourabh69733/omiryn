# Application
APP_ENV=local
APP_NAME=omiryn
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=debug

# Database
DATABASE_URL=postgresql+psycopg://omiryn:omiryn@localhost:5432/omiryn

# Redis / queue
REDIS_URL=redis://localhost:6379/0

# AI providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Security
SECRET_KEY=change-me-in-local-env
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Messaging
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
