# Application
APP_ENV=local
APP_NAME=omiryn
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=debug

# Database
# Local default can be SQLite: sqlite:///./data/omiryn.db
# Local Postgres with Docker Compose:
# POSTGRES_DB=omiryn
# POSTGRES_USER=omiryn
# POSTGRES_PASSWORD=omiryn
# POSTGRES_PORT=5432
# DATABASE_URL=postgresql+psycopg://omiryn:omiryn@localhost:5432/omiryn
# Production should use hosted Postgres.
DATABASE_URL=sqlite:///./data/omiryn.db

# Redis / queue
REDIS_URL=redis://localhost:6379/0

# AI providers
# Use "ollama", "groq", or "mock".
AGENT_PROVIDER=mock
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_AVAILABLE_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile
GROQ_INPUT_COST_PER_1M=0
GROQ_OUTPUT_COST_PER_1M=0
USD_TO_INR=0
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_AVAILABLE_MODELS=llama3.1

# Security
SECRET_KEY=change-me-in-local-env
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Messaging
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
